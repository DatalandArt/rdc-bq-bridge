{
  "title": "RDC-BigQuery Bridge",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Bridge healthy",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "min(rdc_redis_connected) * min(rdc_loader_running)", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": {
              "0": { "text": "DEGRADED", "color": "red" },
              "1": { "text": "OK", "color": "green" }
            }}
          ]
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Seconds since last commit",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 4, "y": 0, "w": 5, "h": 4 },
      "targets": [{ "expr": "max(time() - rdc_last_commit_timestamp_seconds)", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 120 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "value_and_name" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Rows committed (last 5m)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 9, "y": 0, "w": 5, "h": 4 },
      "targets": [{ "expr": "sum(increase(rdc_rows_committed_total[5m]))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active device mappings",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 14, "y": 0, "w": 5, "h": 4 },
      "targets": [{ "expr": "rdc_device_mappings_active", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Errors/sec (5m)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 19, "y": 0, "w": 5, "h": 4 },
      "targets": [{ "expr": "sum(rate(rdc_commit_errors_total[5m]))", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Rows committed/sec by table",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{ "expr": "rate(rdc_rows_committed_total[1m])", "legendFormat": "{{table}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "rps" } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Commit latency p50 / p95 / p99",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le, table) (rate(rdc_commit_latency_seconds_bucket[5m])))", "legendFormat": "p50 {{table}}", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le, table) (rate(rdc_commit_latency_seconds_bucket[5m])))", "legendFormat": "p95 {{table}}", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by (le, table) (rate(rdc_commit_latency_seconds_bucket[5m])))", "legendFormat": "p99 {{table}}", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Queue depths (backpressure)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [{ "expr": "rdc_queue_depth", "legendFormat": "{{queue}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Rows ingested/sec by source",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [{ "expr": "rate(rdc_rows_ingested_total[1m])", "legendFormat": "{{source}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "rps" } }
    }
  ]
}
